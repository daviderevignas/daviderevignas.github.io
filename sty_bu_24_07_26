:root {
  --dark: #111111;
  --dark-soft: #2a2520;
  --light: #f7f2e8;
  --panel: #fffaf0;
  --text: #2b2520;
  --muted: #7a6b5d;
  --accent: #c9a66b;
  --accent-dark: #7b5e2f;
  --max-width: 1050px;
}

